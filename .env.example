# Server
PORT=3001
JWT_SECRET=your-secret-key-change-in-production
NODE_ENV=development

# Embedding Generation (OpenRouter API for text-embedding-3-large model)
# Required for semantic vector search with Pinecone
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-...

# Answer Generation (Google Gemini via Langchain)
# Optional: Uses Gemini for answer generation (falls back to extractive mode if not set)
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=AIza...
# Primary Gemini model (recommended: gemini-2.5-pro)
GEMINI_MODEL=gemini-2.5-pro
# Fallback models used automatically when the primary model is unavailable
GEMINI_FALLBACK_MODELS=gemini-2.5-flash,gemini-1.5-flash
# Vision extraction from rendered PDF pages (disabled by default for fast processing)
GEMINI_VISION_ENABLED=false
# Primary model for Vision extraction
GEMINI_VISION_MODEL=gemini-2.5-flash
# Fallback models for Vision extraction
GEMINI_VISION_FALLBACK_MODELS=gemini-1.5-flash
# Fallback path: send PDF directly to Gemini when page rendering fails
GEMINI_VISION_PDF_FALLBACK=true
# Maximum pages sent to Gemini Vision when enabled
GEMINI_VISION_MAX_PAGES=10
# Total Vision stage timeout in milliseconds when enabled
GEMINI_VISION_TIMEOUT_MS=90000

# Vector Database (Pinecone)
# Optional: Enables semantic search (falls back to BM25-only if not set)
# Get your API key from: https://www.pinecone.io/
PINECONE_API_KEY=pcsk_...
PINECONE_INDEX_NAME=pdf-qa-bot
# Optional: used when auto-creating an index if it does not exist
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# Search Configuration
# Options: bm25 (keyword only), pinecone (semantic only), hybrid (both - recommended)
# Default: hybrid
SEARCH_MODE=hybrid

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:3001/api
